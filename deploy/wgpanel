#!/usr/bin/env bash
#
# wgpanel - management CLI for the WGPanel control-plane stack.
# Installed to /usr/local/bin/wgpanel by deploy/install.sh.
#
set -euo pipefail

INSTALL_DIR="/opt/wgpanel"
ENV_FILE="$INSTALL_DIR/.env"
BACKUP_DIR="$INSTALL_DIR/backups"
STATE_DIR="$INSTALL_DIR/state"
LAST_GOOD_FILE="$STATE_DIR/last-known-good-images.txt"
BACKUP_RETENTION_DAYS="${WGPANNEL_BACKUP_RETENTION_DAYS:-14}"
HEALTH_TIMEOUT_SECONDS="${WGPANNEL_HEALTH_TIMEOUT_SECONDS:-90}"

log()  { echo -e "\033[1;32m[wgpanel]\033[0m $*"; }
warn() { echo -e "\033[1;33m[wgpanel]\033[0m $*"; }
err()  { echo -e "\033[1;31m[wgpanel]\033[0m $*" >&2; }

cd "$INSTALL_DIR"

env_get() { grep "^${1}=" "$ENV_FILE" | head -n1 | cut -d= -f2-; }

api_port() { env_get API_PORT; }
internal_token() { env_get INTERNAL_API_TOKEN; }
panel_url() { echo "https://$(env_get PANEL_DOMAIN)"; }

# curl wrapper for /internal/* calls: attaches the shared secret required by the API's
# internal-token middleware (see docs/PRD-security-access-control.md §5) - loopback/Caddy
# routing alone doesn't stop a sibling container from reaching api:8080 directly.
internal_curl() {
  curl -fsS -H "X-Internal-Token: $(internal_token)" "$@"
}

# ---- health ----

wait_for_health() {
  local timeout="${1:-$HEALTH_TIMEOUT_SECONDS}" waited=0
  local port; port="$(api_port)"
  log "Waiting for API to become healthy (timeout ${timeout}s)..."
  while (( waited < timeout )); do
    if internal_curl "http://127.0.0.1:${port}/internal/healthz" >/dev/null 2>&1; then
      return 0
    fi
    sleep 3
    waited=$((waited + 3))
  done
  return 1
}

cmd_status() {
  docker compose ps
  echo
  local port; port="$(api_port)"
  if internal_curl "http://127.0.0.1:${port}/internal/healthz" 2>/dev/null; then
    echo
    log "API: healthy"
  else
    warn "API: not responding on /internal/healthz"
  fi
  echo
  log "Panel address: $(panel_url)"
}

cmd_doctor() {
  echo "== wgpanel doctor =="

  # Disk space
  local avail_kb; avail_kb=$(df -Pk "$INSTALL_DIR" | tail -1 | awk '{print $4}')
  if (( avail_kb < 2*1024*1024 )); then
    warn "Low disk space: $((avail_kb/1024))MB free under $INSTALL_DIR"
  else
    log "Disk space OK: $((avail_kb/1024))MB free"
  fi

  # Container health
  if docker compose ps --status running --format '{{.Name}}' | grep -q .; then
    log "Containers running: $(docker compose ps --status running --format '{{.Name}}' | tr '\n' ' ')"
  else
    err "No containers are running - try: wgpanel start"
  fi

  # DB reachability
  if docker compose exec -T db pg_isready -U "$(env_get POSTGRES_USER)" >/dev/null 2>&1; then
    log "Postgres/Timescale: reachable"
  else
    err "Postgres/Timescale: NOT reachable"
  fi

  # Redis reachability
  if docker compose exec -T redis redis-cli -a "$(env_get REDIS_PASSWORD)" ping >/dev/null 2>&1; then
    log "Redis: reachable"
  else
    err "Redis: NOT reachable"
  fi

  # API internal health
  if internal_curl "http://127.0.0.1:$(api_port)/internal/healthz" >/dev/null 2>&1; then
    log "API: healthy"
  else
    err "API: NOT healthy"
  fi

  # TLS cert expiry
  local domain; domain="$(env_get PANEL_DOMAIN)"
  local exp
  exp=$(echo | openssl s_client -servername "$domain" -connect "${domain}:443" 2>/dev/null \
        | openssl x509 -noout -enddate 2>/dev/null | cut -d= -f2 || true)
  if [[ -n "$exp" ]]; then
    log "TLS cert for ${domain} expires: ${exp}"
  else
    warn "Could not read TLS cert for ${domain} (may still be provisioning)"
  fi

  # Backup hygiene
  local latest
  latest=$(ls -t "$BACKUP_DIR"/wgpanel-backup-*.tar.gz 2>/dev/null | head -n1 || true)
  if [[ -z "$latest" ]]; then
    warn "No backups found yet - run: wgpanel backup"
  else
    local age_days=$(( ( $(date +%s) - $(stat -c %Y "$latest" 2>/dev/null || stat -f %m "$latest") ) / 86400 ))
    if (( age_days > 2 )); then
      warn "Latest backup is ${age_days} day(s) old (${latest}) - consider running: wgpanel backup"
    else
      log "Latest backup: ${latest} (${age_days}d old)"
    fi
  fi

  echo "== end doctor report =="
}

# ---- lifecycle ----

cmd_start()   { docker compose up -d; }
cmd_stop()    { docker compose down; }
cmd_restart() { docker compose restart "${1:-}"; }
cmd_logs()    { docker compose logs -f --tail=200 "${1:-}"; }

# ---- backup / restore ----

cmd_backup() {
  mkdir -p "$BACKUP_DIR"
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  local workdir; workdir="$(mktemp -d)"
  # `trap ... RETURN` is NOT scoped to this function - it stays armed for the
  # RETURN of whatever function executes next in the same shell (e.g. cmd_update,
  # which calls cmd_backup as one step among several). Without resetting it before
  # returning, it re-fires later against a $workdir that's already out of scope,
  # which under `set -u` is "workdir: unbound variable" - a real bug hit live,
  # surfacing at a completely unrelated point later in the script.
  trap 'rm -rf "$workdir"; trap - RETURN' RETURN

  log "Dumping database..."
  docker compose exec -T db pg_dump -U "$(env_get POSTGRES_USER)" "$(env_get POSTGRES_DB)" > "$workdir/db.sql"
  cp "$ENV_FILE" "$workdir/.env"

  local archive="$BACKUP_DIR/wgpanel-backup-${ts}.tar.gz"
  tar czf "$archive" -C "$workdir" db.sql .env
  log "Backup written to $archive"

  # Retention: prune backups older than WGPANNEL_BACKUP_RETENTION_DAYS
  find "$BACKUP_DIR" -name 'wgpanel-backup-*.tar.gz' -mtime "+${BACKUP_RETENTION_DAYS}" -print -delete \
    | sed 's/^/  pruned old backup: /' || true
}

cmd_restore() {
  local archive="${1:-}"
  if [[ -z "$archive" || ! -f "$archive" ]]; then
    err "Usage: wgpanel restore <backup-file.tar.gz>"
    exit 1
  fi
  read -rp "This will OVERWRITE the current database with the contents of ${archive}. Type 'yes' to confirm: " c
  [[ "$c" == "yes" ]] || { log "Aborted."; exit 0; }

  local workdir; workdir="$(mktemp -d)"
  # See cmd_backup's comment above - RETURN traps aren't function-scoped in bash, so
  # this must reset itself before returning or it re-fires later against an
  # out-of-scope $workdir.
  trap 'rm -rf "$workdir"; trap - RETURN' RETURN
  tar xzf "$archive" -C "$workdir"

  log "Restoring database..."
  cat "$workdir/db.sql" | docker compose exec -T db psql -U "$(env_get POSTGRES_USER)" "$(env_get POSTGRES_DB)"
  log "Restore complete. Restart the API to pick up any state changes: wgpanel restart api"
}

# ---- update / rollback ----

cmd_update() {
  log "Taking a pre-update backup..."
  cmd_backup

  mkdir -p "$STATE_DIR"
  log "Recording current image versions for rollback..."
  docker compose images --format '{{.Repository}}:{{.Tag}}' > "$LAST_GOOD_FILE" 2>/dev/null || \
    docker compose config --images > "$LAST_GOOD_FILE"

  log "Pulling latest images..."
  docker compose pull

  log "Recreating containers..."
  docker compose up -d

  if wait_for_health "$HEALTH_TIMEOUT_SECONDS"; then
    log "Update successful. Current versions:"
    cmd_version
    log "Panel address: $(panel_url)"
  else
    err "Health check failed after update - rolling back to the previous known-good images."
    cmd_rollback
    exit 1
  fi
}

cmd_rollback() {
  if [[ ! -f "$LAST_GOOD_FILE" ]]; then
    err "No recorded known-good version to roll back to (nothing to do)."
    exit 1
  fi
  warn "Rolling back is best-effort: it restarts the stack against whatever images are cached locally"
  warn "from before the last 'wgpanel update'. If those images were pruned, this will not work -"
  warn "restore from a database backup instead: wgpanel restore <backup-file>"
  docker compose up -d
  wait_for_health "$HEALTH_TIMEOUT_SECONDS" && log "Rollback health check passed." || err "Rollback health check also failed - manual intervention needed."
}

cmd_version() {
  docker compose images 2>/dev/null || docker compose config --images
}

# ---- admin management ----

cmd_create_admin() {
  local username="" password=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username) username="$2"; shift 2 ;;
      --password) password="$2"; shift 2 ;;
      *) err "Unknown flag: $1"; exit 1 ;;
    esac
  done

  if [[ -z "$username" ]]; then
    read -rp "New admin username: " username
  fi
  if [[ -z "$password" ]]; then
    password="$(openssl rand -hex 24 | cut -c1-16)"
  fi

  local port; port="$(api_port)"
  local resp
  resp=$(internal_curl -X POST "http://127.0.0.1:${port}/internal/admins" \
    -H 'Content-Type: application/json' \
    -d "{\"username\":\"${username}\",\"password\":\"${password}\",\"role\":\"super_admin\"}")

  echo
  echo "=============================================="
  echo " Super admin created - save these credentials "
  echo "=============================================="
  echo "  Username: ${username}"
  echo "  Password: ${password}"
  echo "=============================================="
  echo
}

# Re-displays the credentials the API auto-created on its very first boot against a
# fresh database (see cmd/api/main.go's bootstrapFirstAdmin) - useful if the admin
# missed them scrolling past during `install.sh`. Only ever prints something if that
# exact log line is still present in `docker compose logs api`'s retained history.
cmd_show_bootstrap_admin() {
  local creds
  creds="$(docker compose logs api 2>/dev/null | grep 'WGPANEL_INITIAL_ADMIN_' || true)"
  if [[ -z "$creds" ]]; then
    err "No bootstrap-admin credentials found in the API's current log history."
    err "Either an admin already existed before this container's first boot, or the logs have rotated/been cleared."
    err "Create a new one instead with: wgpanel create-admin --username <name>"
    exit 1
  fi
  echo "$creds" | sed -E 's/^.*(WGPANEL_INITIAL_ADMIN_[A-Z]+=.*)$/\1/'
}

# ---- destructive ----

cmd_uninstall() {
  read -rp "This stops containers and DELETES all data volumes. Type 'yes' to confirm: " c
  [[ "$c" == "yes" ]] && docker compose down -v
}

usage() {
  cat <<'EOF'
wgpanel - manage the WGPanel control-plane stack

Usage: wgpanel <command> [args]

Lifecycle:
  start                   Start the stack
  stop                    Stop the stack (data volumes preserved)
  restart [service]       Restart everything, or one service
  status                  Show container + API health status

Day-2 operations:
  update                  Backup, pull latest images, redeploy, auto-rollback on failed health check
  rollback                Redeploy the last known-good image set (best-effort; prefer restore for real recovery)
  backup                  Dump the database + .env into deploy/backups (auto-pruned after 14 days)
  restore <file>          Restore the database from a backup archive (destructive, asks for confirmation)
  doctor                  Check disk space, container/DB/Redis health, TLS cert expiry, backup freshness
  logs [service]          Tail logs

Admin accounts:
  create-admin [--username NAME] [--password PASS]
                          Create an additional super admin (the very first one is
                          auto-created by the API itself on first boot - see
                          show-bootstrap-admin to recover those credentials)
  show-bootstrap-admin    Re-display the auto-created first-boot super admin credentials,
                          if still present in the API's log history

Other:
  uninstall               Stop and delete all data volumes (destructive, asks for confirmation)
EOF
}

main() {
  local cmd="${1:-}"
  [[ $# -gt 0 ]] && shift || true
  case "$cmd" in
    start) cmd_start ;;
    stop) cmd_stop ;;
    restart) cmd_restart "$@" ;;
    status) cmd_status ;;
    logs) cmd_logs "$@" ;;
    update) cmd_update ;;
    rollback) cmd_rollback ;;
    backup) cmd_backup ;;
    restore) cmd_restore "$@" ;;
    doctor) cmd_doctor ;;
    version) cmd_version ;;
    create-admin) cmd_create_admin "$@" ;;
    show-bootstrap-admin) cmd_show_bootstrap_admin ;;
    uninstall) cmd_uninstall ;;
    *) usage ;;
  esac
}

main "$@"
