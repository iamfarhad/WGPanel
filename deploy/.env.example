# ---- Copy to .env and fill in / let install.sh auto-generate secrets ----

# Public domain the panel will be served on (used by Caddy for automatic HTTPS)
PANEL_DOMAIN=panel.example.com
ADMIN_ACL_EMAIL=admin@example.com

# Public HTTP/HTTPS ports Caddy binds on this host - change these only if 80/443 are
# already used by another service on this server. Automatic HTTPS/Let's Encrypt
# assumes 443 is reachable from the internet on this port; a non-standard HTTPS
# port means visiting the panel requires typing https://domain:PORT explicitly.
PANEL_HTTP_PORT=80
PANEL_HTTPS_PORT=443

# Postgres / TimescaleDB
POSTGRES_USER=wgpanel
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=wgpanel
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=CHANGE_ME

# API
# Host-side ports below deliberately sit in a high, rarely-used range (48xxx) to avoid
# colliding with common services: 8080/3000 are used by countless apps, and 9090 (the
# old NODE_AGENT_PORT) is Cockpit's and Prometheus's default - a frequent clash on
# Ubuntu servers. API_PORT and FRONTEND_PORT are bound to 127.0.0.1 only (loopback);
# NODE_AGENT_PORT is the only one exposed publicly (node agents dial it over mTLS).
API_PORT=48080
# Loopback debug port for the frontend container (Caddy proxies it internally either way).
FRONTEND_PORT=48088
JWT_SECRET=CHANGE_ME
# AES-256-GCM key (32 random bytes, hex-encoded) that encrypts bot/reseller API key
# secrets at rest (api_keys.secret_encrypted, STORY-05). HMAC signature verification
# needs the raw secret recoverable server-side - it can't be one-way hashed like a
# password - so this protects it at rest the same way ACCOUNT_KEY_ENCRYPTION_KEY
# protects WireGuard private keys.
API_HMAC_MASTER_KEY=CHANGE_ME
# Public mTLS port node agents connect back to (was 9090, which clashes with Cockpit/
# Prometheus). Nodes reach this as <panel-host>:48443, so it must be open to the internet.
NODE_AGENT_PORT=48443
NODE_AGENT_JOIN_TOKEN_TTL_MIN=30

# Username for the super admin the API auto-creates on its very first successful boot
# against a fresh database (gated on admins table being empty - never re-triggers after
# that, even across restarts/updates). The generated password is printed once to the api
# container's logs (`wgpanel logs api` / `docker compose logs api`) and nowhere else -
# install.sh surfaces it directly after first install.
ADMIN_BOOTSTRAP_USERNAME=admin

# Shared secret required on every /internal/* call (X-Internal-Token header). This is what
# actually gates /internal/* - Docker's 127.0.0.1-only port publish and Caddy not proxying the
# path keep it off the public internet, but any sibling container on the same compose network
# (frontend, caddy) can otherwise reach api:8080 directly, so IP alone is not a real boundary.
INTERNAL_API_TOKEN=CHANGE_ME

# AES-256-GCM key (32 random bytes, hex-encoded) used only to encrypt account private keys
# at rest. Deliberately separate from API_HMAC_MASTER_KEY (reserved for bot-API request
# signing) - one key per cryptographic purpose, not shared just because both are "secrets".
ACCOUNT_KEY_ENCRYPTION_KEY=CHANGE_ME

# Dev-only WireGuard node running in Docker (deploy/node.Dockerfile) - see the
# wg-node service comment in docker-compose.yml. Only needed if you start it via
# `docker compose --profile node up wg-node`; irrelevant otherwise.
# Generate NODE_JOIN_TOKEN from the admin panel: Nodes -> Add Node -> Generate Token.
NODE_JOIN_TOKEN=
NODE_NAME=dev-docker-node
NODE_WG_IFACE=wg0
NODE_WG_PORT=51820
NODE_WG_IFACE_ADDR=10.66.0.1/24

# ---- Resource limits (optional) ----
# Per-container memory ceilings enforced by docker-compose.yml. These are caps that
# protect the host from a runaway container, NOT reservations - actual idle usage is a
# small fraction of them. Defaults suit a 2GB+ VPS; lower them on a tiny host or raise
# DB_MEM_LIMIT for a large fleet. Uncomment to override the built-in defaults.
# DB_MEM_LIMIT=1g
# REDIS_MEM_LIMIT=384m
# REDIS_MAXMEMORY=256mb
# API_MEM_LIMIT=512m
# FRONTEND_MEM_LIMIT=128m
# CADDY_MEM_LIMIT=256m

# Container images - published by .github/workflows/build-{api,frontend}.yml on
# every push to main. If you've forked this repo, replace `iamfarhad` with your own
# GitHub username/org (and make sure the packages are public - GHCR packages are
# private by default even in a public repo, see Settings -> Packages on GitHub).
API_IMAGE=ghcr.io/iamfarhad/wgpanel-api:latest
FRONTEND_IMAGE=ghcr.io/iamfarhad/wgpanel-frontend:latest
# Production WireGuard node image (deploy/node.Dockerfile), published by
# .github/workflows/build-node.yml. Used by install-node.sh (remote nodes) and
# install.sh's self-node - both run the node as a Docker container, not bare metal.
NODE_IMAGE=ghcr.io/iamfarhad/wgpanel-node:latest
